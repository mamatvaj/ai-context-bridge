{
  "manifest_version": 3,
  "name": "AI Context Bridge",
  "version": "1.20",
  "description": "Send selected text or full-page content directly into Claude, ChatGPT, and Grok \u2014 no API needed.",
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting",
    "contextMenus"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_end",
      "exclude_matches": [
        "https://claude.ai/*",
        "https://chatgpt.com/*",
        "https://gemini.google.com/*",
        "https://www.meta.ai/*",
        "https://grok.com/*",
        "https://x.ai/*"
      ]
    },
    {
      "matches": [
        "https://claude.ai/*"
      ],
      "js": [
        "injectors/claude.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://chatgpt.com/*"
      ],
      "js": [
        "injectors/chatgpt.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://gemini.google.com/*"
      ],
      "js": [
        "injectors/gemini.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.meta.ai/*"
      ],
      "js": [
        "injectors/meta.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://grok.com/*",
        "https://x.ai/*"
      ],
      "js": [
        "injectors/grok.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "AI Context Bridge",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "Help_Guide.html"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}